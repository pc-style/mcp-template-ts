# Autonomous Development Team MCP Server Configuration

# LLM Provider Configuration
# Choose one of: openai, anthropic, local
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4000

# Anthropic Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_TEMPERATURE=0.7
ANTHROPIC_MAX_TOKENS=4000

# Local Model Configuration (e.g., Ollama)
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL_NAME=llama2
LOCAL_MODEL_TEMPERATURE=0.7
LOCAL_MODEL_MAX_TOKENS=4000

# Project Configuration
PROJECT_TEMP_DIR=./temp-projects
PROJECT_OUTPUT_DIR=./output-projects

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/mcp-server.log

# Security Configuration
ENCRYPTION_KEY=your-encryption-key-here
JWT_SECRET=your-jwt-secret-here

# Performance Configuration
MAX_CONCURRENT_PROJECTS=5
REQUEST_TIMEOUT=300000
CACHE_TTL=3600

# Development Configuration
NODE_ENV=development
DEBUG=false