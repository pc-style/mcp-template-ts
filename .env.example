# MCP Autonomous Development Team - Environment Configuration

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_organization_id_here
OPENAI_MODEL=gpt-4

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Local LLM Configuration (for Ollama, LM Studio, etc.)
LOCAL_LLM_ENDPOINT=http://localhost:11434
LOCAL_LLM_MODEL=llama2

# Default LLM Provider (openai, anthropic, local)
DEFAULT_LLM_PROVIDER=openai

# =============================================================================
# Project Configuration
# =============================================================================

# Project paths and settings
PROJECT_DEFAULT_PATH=./generated-projects
PROJECT_TEMPLATES_PATH=./templates
MAX_CONCURRENT_TASKS=3
TASK_TIMEOUT_MINUTES=30

# =============================================================================
# Git Configuration
# =============================================================================

# Git integration settings
GIT_ENABLED=true
GIT_AUTO_COMMIT=true
GIT_COMMIT_MESSAGE=Auto-generated by MCP Dev Team
GIT_BRANCH=main

# =============================================================================
# File System Configuration
# =============================================================================

# File size limits and allowed extensions
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=.js,.ts,.jsx,.tsx,.py,.go,.java,.rb,.php,.html,.css,.scss,.json,.yaml,.yml,.md,.txt,.sql,.sh,.dockerfile,.gitignore

# =============================================================================
# Logging Configuration
# =============================================================================

# Log levels: debug, info, warn, error
LOG_LEVEL=info

# Log format: text, json
LOG_FORMAT=text

# File logging settings
ENABLE_FILE_LOGGING=false
LOG_FILE_PATH=./logs/mcp-dev-team.log

# =============================================================================
# Security Configuration
# =============================================================================

# Sandbox mode for security
ENABLE_SANDBOX=true

# Allowed commands (comma-separated)
ALLOWED_COMMANDS=npm,yarn,pnpm,pip,poetry,go,cargo,git,docker,docker-compose,kubectl

# Blocked commands (comma-separated)
BLOCKED_COMMANDS=rm,del,format,dd,mkfs,fdisk

# =============================================================================
# Agent Configuration
# =============================================================================

# Product Manager Agent
PM_ENABLED=true
PM_MODEL=gpt-4
PM_TEMPERATURE=0.7

# Tech Lead Agent
TL_ENABLED=true
TL_MODEL=gpt-4
TL_TEMPERATURE=0.5

# Developer Agent
DEV_ENABLED=true
DEV_MODEL=gpt-4
DEV_TEMPERATURE=0.3

# QA Engineer Agent
QA_ENABLED=true
QA_MODEL=gpt-4
QA_TEMPERATURE=0.4

# DevOps Engineer Agent
DEVOPS_ENABLED=true
DEVOPS_MODEL=gpt-4
DEVOPS_TEMPERATURE=0.6

# =============================================================================
# Validation Configuration
# =============================================================================

# Code quality and validation settings
ENABLE_CODE_REVIEW=true
ENABLE_SECURITY_SCAN=true
ENABLE_LINTING=true
REQUIRE_TESTS=true
MIN_TEST_COVERAGE=80

# =============================================================================
# Example Configurations
# =============================================================================

# For development with OpenAI:
# OPENAI_API_KEY=sk-your-actual-key-here
# DEFAULT_LLM_PROVIDER=openai

# For development with Anthropic:
# ANTHROPIC_API_KEY=sk-ant-your-actual-key-here
# DEFAULT_LLM_PROVIDER=anthropic

# For development with local models:
# LOCAL_LLM_ENDPOINT=http://localhost:11434
# LOCAL_LLM_MODEL=llama2
# DEFAULT_LLM_PROVIDER=local

# For debugging:
# LOG_LEVEL=debug
# ENABLE_FILE_LOGGING=true

# For production:
# LOG_LEVEL=warn
# ENABLE_SANDBOX=true
# GIT_ENABLED=true